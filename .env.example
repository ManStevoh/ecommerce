# Nexora Commerce — copy to .env and per-service .env files

# Database (PostgreSQL 16)
DATABASE_URL="postgresql://nexora:nexora_secret@localhost:5432/nexora?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="nexora_meili_master_key"

# Platform
PLATFORM_DOMAIN="nexora.local"
API_GATEWAY_URL="http://localhost:3000"

# AI (Phase 3)
OPENAI_API_KEY=""

# Payments (per-tenant keys stored in DB; platform defaults for dev)
STRIPE_SECRET_KEY=""
PAYSTACK_SECRET_KEY=""
FLUTTERWAVE_SECRET_KEY=""
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE=""
