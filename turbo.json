{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "MEILISEARCH_HOST",
    "MEILISEARCH_API_KEY",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_TENANT_ID",
    "NEXT_PUBLIC_TENANT_SUBDOMAIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": []
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
